// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Student {
  id                 Int               @id @default(autoincrement())
  matric_number      String            @unique
  full_name          String
  email              String            @unique
  password_hash      String
  biometric_template Bytes?

  enrollments        Enrollment[]
  attendanceRecords  AttendanceRecord[]
}

model Lecturer {
  id            Int       @id @default(autoincrement())
  staff_id      String    @unique
  full_name     String
  email         String    @unique
  password_hash String

  courses       Course[]
}

model Course {
  id           Int                 @id @default(autoincrement())
  course_code  String              @unique
  course_title String
  lecturer_id  Int

  lecturer          Lecturer            @relation(fields: [lecturer_id], references: [id], onDelete: Cascade)
  enrollments       Enrollment[]
  sessions          AttendanceSession[]
  sessionSchedules  SessionSchedule[]

  @@index([lecturer_id])
}

model Enrollment {
  id         Int     @id @default(autoincrement())
  student_id Int
  course_id  Int

  student    Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course     Course  @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([student_id, course_id])
  @@index([course_id])
}

/// Recurring rule: open/close attendance sessions on selected weekdays between dates.
model SessionSchedule {
  id              Int      @id @default(autoincrement())
  course_id       Int
  start_date      DateTime @db.Date
  end_date        DateTime @db.Date
  daily_start_time String  // "HH:mm" 24-hour
  daily_end_time   String  // "HH:mm" 24-hour
  days_of_week    Int[]    // 0=Sunday … 6=Saturday (JS Date.getDay())
  is_enabled      Boolean  @default(true)
  created_at      DateTime @default(now())

  course   Course              @relation(fields: [course_id], references: [id], onDelete: Cascade)
  sessions AttendanceSession[]

  @@index([course_id])
  @@index([is_enabled, start_date, end_date])
}

model AttendanceSession {
  id              Int       @id @default(autoincrement())
  course_id       Int
  start_time      DateTime
  end_time        DateTime?
  schedule_id     Int?
  scheduled_date  DateTime? @db.Date
  manually_started Boolean  @default(false)
  manually_ended   Boolean  @default(false)

  course   Course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  schedule SessionSchedule? @relation(fields: [schedule_id], references: [id], onDelete: SetNull)
  records  AttendanceRecord[]

  @@index([course_id, start_time])
  @@index([schedule_id, scheduled_date])
}

model AttendanceRecord {
  id         Int               @id @default(autoincrement())
  session_id Int
  student_id Int
  timestamp  DateTime          @default(now())
  status     AttendanceStatus

  session    AttendanceSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  student    Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([session_id, student_id])
  @@index([student_id, timestamp])
}
